---
import Layout from '../layouts/Layout.astro';
import categoriesData from '../content/categories.json';

const categories = categoriesData
  .filter(cat => cat.count > 0)
  .sort((a, b) => b.count - a.count);
---

<Layout title="Categories - Koala Pickleball">
  <div style="max-width: 1200px; margin: 0 auto; padding: 3rem 2rem;">
    <h1 style="font-size: 2.5rem; color: var(--color-primary); margin-bottom: 1rem; text-align: center;">
      All Categories
    </h1>
    <p style="text-align: center; color: var(--color-text-light); margin-bottom: 3rem;">
      Browse articles by topic
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem;">
      {categories.map((category) => (
        <a 
          href={`/category/${category.slug}`}
          style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); padding: 2rem; border-radius: 12px; text-decoration: none; color: var(--color-text); transition: transform 0.3s, box-shadow 0.3s; border: 1px solid #dee2e6; display: flex; justify-content: space-between; align-items: center;"
        >
          <div>
            <h2 style="font-size: 1.4rem; margin-bottom: 0.5rem; color: var(--color-primary);">{category.name}</h2>
            <p style="color: var(--color-text-light);">{category.count} articles</p>
          </div>
          <span style="font-size: 1.5rem; color: var(--color-accent);">→</span>
        </a>
      ))}
    </div>
  </div>
</Layout>
